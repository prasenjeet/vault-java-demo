{
  "title": "Vault Java Demo",
  "uid": "vault-java-demo",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "tags": ["vault", "java", "prometheus"],
  "panels": [

    {
      "type": "row",
      "title": "Overview",
      "id": 100,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "id": 1,
      "title": "Vault Operations / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (engine) (rate(vault_operations_total{status=\"success\"}[1m]))",
          "legendFormat": "{{engine}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "id": 2,
      "title": "Operation Duration P95 (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (engine, le) (rate(vault_operation_duration_seconds_bucket[1m])))",
          "legendFormat": "{{engine}} p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (engine, le) (rate(vault_operation_duration_seconds_bucket[1m])))",
          "legendFormat": "{{engine}} p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "id": 3,
      "title": "Total Operations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(vault_operations_total{status=\"success\"})",
          "legendFormat": "Successful",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 4,
      "title": "Error Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(vault_operations_total{status=\"error\"}) or vector(0)",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1    }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 5,
      "title": "Key Rotations (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(vault_transit_key_rotations_total) or vector(0)",
          "legendFormat": "Rotations",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 6,
      "title": "DB Credential TTL",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "vault_db_credential_ttl_seconds",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 7,
      "title": "PKI Cert TTL",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "vault_pki_cert_ttl_seconds",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 8,
      "title": "SSH Cert TTL",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "vault_ssh_cert_ttl_seconds",
          "legendFormat": "{{principals}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "type": "row",
      "title": "Secret Engine Breakdown",
      "id": 200,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }
    },

    {
      "id": 10,
      "title": "Transit Engine — Operations / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (operation) (rate(vault_operations_total{engine=\"transit\",status=\"success\"}[1m]))",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "id": 11,
      "title": "Transit Engine — Latency P95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (operation, le) (rate(vault_operation_duration_seconds_bucket{engine=\"transit\"}[1m])))",
          "legendFormat": "{{operation}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "id": 12,
      "title": "Database — Credential Fetches / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (operation, status) (rate(vault_operations_total{engine=\"database\"}[1m]))",
          "legendFormat": "{{operation}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "id": 13,
      "title": "PKI — Certificate Operations / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (operation, status) (rate(vault_operations_total{engine=\"pki\"}[1m]))",
          "legendFormat": "{{operation}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "id": 14,
      "title": "SSH — OTP & Certificate Operations / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (operation, status) (rate(vault_operations_total{engine=\"ssh\"}[1m]))",
          "legendFormat": "{{operation}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "id": 15,
      "title": "Transit Key Rotations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "increase(vault_transit_key_rotations_total[5m])",
          "legendFormat": "{{key}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "drawStyle": "bars" },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "type": "row",
      "title": "JVM Runtime",
      "id": 300,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 }
    },

    {
      "id": 20,
      "title": "JVM Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "jvm_memory_bytes_used{area=\"heap\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_bytes_max{area=\"heap\"}",
          "legendFormat": "Max",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 21,
      "title": "JVM GC — Collection Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(jvm_gc_collection_seconds_sum[1m])",
          "legendFormat": "{{gc}} GC time/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 22,
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "jvm_threads_current",
          "legendFormat": "Current",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon",
          "legendFormat": "Daemon",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }

  ],

  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "current": {}
      }
    ]
  }
}
